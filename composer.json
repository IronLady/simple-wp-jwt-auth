{
    "name": "tokodash/jwt-auth-pro-ext",
    "description": "Best-practice extensions (refresh tokens, rotation, revocation, rate limiting) for the JWT Authentication for WP-API plugin.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "version": "1.0.0",
    "require": {
        "php": ">=7.4",
        "composer/installers": "^2.0",
        "wpackagist-plugin/jwt-authentication-for-wp-rest-api": "^1.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "yoast/phpunit-polyfills": "^2.0"
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://wpackagist.org"
        }
    ],
    "extra": {
        "installer-paths": {
            "vendor/wp-plugins/{$name}/": [
                "type:wordpress-plugin"
            ]
        }
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true
        }
    }
}
